// This is a Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// TODO: S04 — add Template, Order models

model Bead {
  id        Int      @id @default(autoincrement())
  name      String
  nameRu    String
  shape     String   // "sphere" | "disc" | "star" | "heart" | "cylinder" — mapped in app
  size      Float
  material  String   // "wood" | "silicone" | "knit" | "plastic" — mapped in app
  color     String
  createdAt DateTime @default(now())
}
