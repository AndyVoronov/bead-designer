// This is a Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Bead {
  id        Int      @id @default(autoincrement())
  name      String
  nameRu    String
  shape     String   // "sphere" | "disc" | "star" | "heart" | "cylinder" — mapped in app
  size      Float
  material  String   // "wood" | "silicone" | "knit" | "plastic" — mapped in app
  color     String
  createdAt DateTime @default(now())
}

model User {
  id        Int       @id @default(autoincrement())
  name      String?
  email     String?   @unique
  avatar    String?
  phone     String?
  createdAt DateTime  @default(now())
  accounts  Account[]
  designs   SavedDesign[]
  favorites Favorite[]
  reviews   Review[]
  orders    Order[]
}

model Account {
  id         Int    @id @default(autoincrement())
  provider   String // "yandex" | "vkontakte" | "telegram"
  providerId String
  accountId  String? // provider-specific user id (username, etc.)
  userId     Int
  user       User   @relation(fields: [userId], references: [id])

  @@unique([provider, providerId])
}

model Template {
  id              Int        @id @default(autoincrement())
  name            String
  designCode      String     @unique
  beadCount       Int
  isApproved      Boolean    @default(true)
  isUserSubmitted Boolean    @default(false)
  favoriteCount   Int        @default(0)
  createdAt       DateTime   @default(now())
  favorites       Favorite[]
}

model Order {
  id          Int      @id @default(autoincrement())
  designCode  String   @unique
  designState String   // JSON string of SerializableDesign
  status      String   @default("new")  // "new" | "processing" | "completed"
  beadCount   Int
  user        User?    @relation(fields: [userId], references: [id])
  userId      Int?
  createdAt   DateTime @default(now())
}

model SavedDesign {
  id         Int      @id @default(autoincrement())
  name       String
  designCode String
  beadCount  Int
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Favorite {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id])
  userId     Int
  template   Template @relation(fields: [templateId], references: [id])
  templateId Int
  createdAt  DateTime @default(now())

  @@unique([userId, templateId])
}

model Review {
  id         Int      @id @default(autoincrement())
  authorName String
  rating     Int      // 1–5
  text       String
  isApproved Boolean  @default(false)
  user       User?    @relation(fields: [userId], references: [id])
  userId     Int?
  createdAt  DateTime @default(now())
}
