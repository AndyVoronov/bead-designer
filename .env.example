DATABASE_URL=postgresql://beaduser:CHANGE_ME@localhost:5432/beaddesigner
ADMIN_LOGIN=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
ADMIN_COOKIE_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
NODE_ENV=production
PORT=3000

# Auth.js / NextAuth
AUTH_SECRET=CHANGE_ME_TO_RANDOM_32_CHAR_STRING
AUTH_TRUST_HOST=true
NEXTAUTH_URL=https://5minutesofsilence.ru

# OAuth Providers (Yandex required, VK and Telegram optional)
AUTH_YANDEX_ID=your_yandex_client_id
AUTH_YANDEX_SECRET=your_yandex_client_secret
# AUTH_VK_ID=your_vk_client_id
# AUTH_VK_SECRET=your_vk_client_secret
# TELEGRAM_BOT_NAME=your_telegram_bot_name

# Telegram Bot API (for order notifications)
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Analytics (optional)
# NEXT_PUBLIC_YM_ID=your_yandex_metrica_id

# Yandex.Delivery API (optional — enables dynamic PVZ cost calculation)
# YANDEX_DELIVERY_API_KEY=your_api_key
# YANDEX_SENDER_ID=your_sender_id

# AI Article Generation (OpenAI-compatible API)
